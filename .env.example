# ============================================================
# IntelliHoneypot — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Backend Selector ---
# Controls which provider answers commands. Change + restart to switch instantly.
# Values: auto | grok | cerebras | openai | anthropic | ollama
#   auto      = tries each configured provider in order (first success wins)
#   <name>    = uses ONLY that provider — good for clean A/B testing
LLM_BACKEND=auto

# --- LLM Backend: Cerebras API (OpenAI-compatible, free tier — very fast) ---
# Get your key at: cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# --- LLM Backend: Grok API (xAI, OpenAI-compatible, free tier) ---
# Get your key at: console.x.ai
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-3-mini
GROK_BASE_URL=https://api.x.ai/v1

# --- LLM Backend: Ollama (Optional — requires good hardware, 4GB+ RAM free) ---
# Set OLLAMA_ENABLED=true AND start with: docker compose --profile local-llm up -d
OLLAMA_ENABLED=false
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_FALLBACK_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECS=5

# --- Cloud API Fallback (used if Grok is unavailable) ---
# Leave blank to disable that provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# --- Structured Logging ---
LOG_LEVEL=INFO
# Set to a valid host/IP to enable CEF syslog forwarding
SYSLOG_HOST=127.0.0.1
SYSLOG_PORT=514

# --- SSH Honeypot ---
SSH_PORT=22
SSH_BCRYPT_DELAY_MIN_MS=200
SSH_BCRYPT_DELAY_MAX_MS=800
SSH_MAX_SESSIONS=30

# --- HTTP Honeypot ---
HTTP_PORT=80

# --- Admin Dashboard ---
DASHBOARD_PORT=9000
# Change this to a strong random secret in production
DASHBOARD_SECRET_KEY=change-me-in-production-use-a-long-random-string
# Admin dashboard login credentials (required for protected dashboard access)
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=change-me

# --- Multi-Agent Mesh (P2P blocklist sharing) ---
# Set to true to enable mesh broadcasting between honeypot nodes
MESH_ENABLED=false
MESH_MULTICAST_GROUP=239.0.0.1
MESH_PORT=9999

#webhook_url
N8N_WEBHOOK_URL=The_url_of_the_workflow